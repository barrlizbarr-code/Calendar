UID:cdd6aabb-384a-461a-b068-c369cf23fc55@liz-training-calendar-v2
DTSTAMP:20260705T183000Z
DTSTART;TZID=America/New_York:20260707T183000
DTEND;TZID=America/New_York:20260707T191500
SUMMARY:Swim — Technique + Endurance
DESCRIPTION:Outdoor pool\n\nWorkout type: Technique + basic endurance\nDu
 ration: 35–40 min\nYardage: 500–650 yd\nEffort: RPE 3–4/10\n\nWarm-up\n4
  x 50 easy\n\nTechnique\n4 x 25 catch-up drill\n4 x 25 fingertip drag\n\
 nMain set\n4 x 50 relaxed\n2 x 100 easy\n\nCool-down\n50 easy\n\nCoachin
 g cue\nExhale continuously underwater. Long reach before each pull.\n\nA
 djustment\nIf tired: do 4 x 50 + drills + 1 x 100 and stop.
LOCATION:Outdoor pool
CATEGORIES:SWIM
STATUS:CONFIRMED
TRANSP:OPAQUE
END:VEVENT
